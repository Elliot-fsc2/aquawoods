# ==================== SUPABASE CONFIGURATION ====================
# Get these from: Supabase Dashboard > Project Settings > API

# Project ID (the subdomain in your Supabase URL)
SUPABASE_PROJECT_ID="your-project-id"

# Supabase URL (e.g. https://xxxxx.supabase.co)
SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Anon / Publishable key (safe for client-side use)
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Service role key (SECRET — server-side only, never expose to client)
# Used in src/integrations/supabase/client.server.ts for admin operations
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ==================== OTHER (if needed) ====================
# Add any other environment variables here
